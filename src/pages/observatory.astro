---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlanetField from '../components/PlanetField.astro';
---

<BaseLayout title="Observatory — Arcane Orion">
  <PlanetField />

  <aside class="sys-info" aria-hidden="true">
    <p>state · five orbits</p>
    <p>status · resolving</p>
    <p>object · observatory</p>
  </aside>

  <div class="relative z-10 page-fade-in">
    <header class="observatory-hero">
      <p class="observatory-label">v. observatory</p>
      <h1 class="observatory-title">五个空间</h1>
      <p class="observatory-sub">
        悬在不同轨道上 — 触碰任意一颗，进入它的内部。
      </p>
    </header>

    <footer class="observatory-foot">
      <a href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/'} class="link-quiet">← back · origin</a>
      <a href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/blog'} class="link-quiet">flat archive ↗</a>
    </footer>
  </div>

  <script>
    (window as any).__BLOG_BASE__ = import.meta.env.BASE_URL.replace(/\/$/, '');
  </script>

  <style>
    .observatory-hero {
      position: fixed;
      top: clamp(2rem, 6vh, 4rem);
      left: 50%;
      transform: translateX(-50%);
      text-align: center;
      pointer-events: none;
      z-index: 5;
      animation: hero-fade 1.4s ease 320ms both;
    }

    .observatory-label {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.42em;
      text-transform: uppercase;
      color: var(--color-text-dim);
      margin: 0;
    }

    .observatory-title {
      margin: 0.8rem 0 0;
      font-family: var(--font-display);
      font-size: clamp(2.6rem, 5vw, 3.8rem);
      letter-spacing: -0.01em;
      color: var(--color-text);
      font-weight: 400;
    }

    .observatory-sub {
      margin: 0.6rem 0 0;
      font-family: var(--font-italic);
      font-style: italic;
      font-size: clamp(0.95rem, 1.4vw, 1.1rem);
      color: var(--color-text-secondary);
      max-width: 28rem;
      line-height: 1.7;
    }

    .observatory-foot {
      position: fixed;
      bottom: clamp(1.5rem, 4vh, 2.4rem);
      left: 0;
      right: 0;
      display: flex;
      justify-content: space-between;
      padding: 0 clamp(1.5rem, 4vw, 3rem);
      pointer-events: auto;
      z-index: 5;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      animation: hero-fade 1.4s ease 600ms both;
    }

    @keyframes hero-fade {
      from { opacity: 0; transform: translateX(-50%) translateY(-12px); }
      to { opacity: 1; transform: translateX(-50%) translateY(0); }
    }

    .observatory-foot {
      animation-name: foot-fade;
    }

    @keyframes foot-fade {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</BaseLayout>
