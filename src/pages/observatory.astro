---
import BaseLayout from '../layouts/BaseLayout.astro';
import Constellation from '../components/Constellation.astro';
---

<BaseLayout title="Observatory — Arcane Orion">
  <Constellation />

  <aside class="sys-info" aria-hidden="true">
    <p data-sys-state>state · five nodes</p>
    <p data-sys-status>status · waiting</p>
    <p data-sys-object>object · constellation</p>
  </aside>

  <div class="relative z-10">
    <footer class="observatory-foot">
      <a href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/'} class="link-quiet">← origin</a>
    </footer>
  </div>

  <script>
    (window as any).__BLOG_BASE__ = import.meta.env.BASE_URL.replace(/\/$/, '');
  </script>

  <style>
    .observatory-foot {
      position: fixed;
      bottom: clamp(1.5rem, 4vh, 2.4rem);
      left: clamp(1.5rem, 4vw, 3rem);
      z-index: 5;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      animation: obs-foot-fade 1.4s ease 800ms both;
    }

    @keyframes obs-foot-fade {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</BaseLayout>
