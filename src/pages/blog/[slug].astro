---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import TagBadge from '../../components/TagBadge.astro';
import AIAssisted from '../../components/AIAssisted.astro';
import StructureField from '../../components/StructureField.astro';
import { getCollection } from 'astro:content';
import { pathFor, primaryDomain, readingMinutes } from '../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (post) => !post.data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const domain = primaryDomain(post.data.tags);
const minutes = readingMinutes(post.body);

const allPosts = await getCollection('blog', (p) => !p.data.draft);
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug && p.data.tags.some(t => post.data.tags.includes(t)))
  .slice(0, 3);
---

<BaseLayout 
  title={`${post.data.title} — Arcane Orion`}
  description={post.data.description}
>
  <StructureField mode={domain.id} />
  <div class="relative z-10">
    <Nav />
    
    <main class="page-shell py-16">
      <article class={`domain-${domain.id} mx-auto max-w-4xl`}>
        <header class="relative overflow-hidden border border-arcane-border bg-white p-6 backdrop-blur-xl md:p-10" style="border-radius:8px">
          <div class="pointer-events-none absolute inset-0 opacity-70">
            <StructureField mode={domain.id} compact />
          </div>
          <div class="relative">
            <div class="mb-8 flex flex-wrap items-center gap-2">
              {post.data.tags.map(tag => <TagBadge tag={tag} />)}
            </div>
            
            <p class="axis-label text-domain">{domain.phrase}</p>
            <h1 class="mt-4 text-balance font-display text-4xl font-bold leading-tight text-arcane-text md:text-6xl">
              {post.data.title}
            </h1>
            
            <div class="mt-8 flex flex-wrap items-center gap-4 font-mono text-[0.72rem] uppercase text-arcane-text-dim">
              <time>{post.data.date.toLocaleDateString('zh-CN')}</time>
              <span>/</span>
              <span>{minutes} min read</span>
              <span>/</span>
              <span>{domain.label} record</span>
            </div>
          </div>
        </header>
        
        <div class="mt-8">
          <AIAssisted show={post.data.aiAssisted} />
        </div>
        
        <div class="observatory-panel mt-8 p-6 md:p-10">
          <div class="prose-arcane prose-lg">
            <Content />
          </div>
        </div>
        
        <footer class="mt-10 flex flex-col justify-between gap-4 border-t border-white/10 pt-8 sm:flex-row sm:items-center">
          <a 
            href={pathFor('/blog')} 
            class="link-quiet font-mono text-xs uppercase"
          >
            ← return archive
          </a>
          
          <button 
            onclick="navigator.clipboard.writeText(window.location.href)"
            class="w-fit border border-arcane-border px-3 py-2 font-mono text-xs uppercase text-arcane-text-secondary transition-colors hover:border-arcane-text-secondary hover:text-arcane-text"
          >
            copy link
          </button>
        </footer>
      </article>
      
      {relatedPosts.length > 0 && (
        <section class="mx-auto mt-20 max-w-4xl">
          <p class="axis-label">related records</p>
          <div class="mt-5 grid gap-3">
            {relatedPosts.map(p => {
              const relatedDomain = primaryDomain(p.data.tags);
              return (
                <a 
                  href={pathFor(`/blog/${p.slug}`)}
                  class={`domain-${relatedDomain.id} grid gap-3 border border-arcane-border bg-white p-4 transition-colors hover:border-domain md:grid-cols-[auto_1fr]`}
                >
                  <span class="grid h-10 w-10 place-items-center border border-domain font-mono text-domain">{relatedDomain.glyph}</span>
                  <span>
                    <span class="block font-display text-arcane-text">{p.data.title}</span>
                    <span class="mt-1 block text-sm text-arcane-text-secondary">{p.data.description}</span>
                  </span>
                </a>
              );
            })}
          </div>
        </section>
      )}
    </main>
    
    <footer class="border-t border-arcane-border py-10">
      <div class="page-shell text-center font-mono text-[0.72rem] uppercase text-arcane-text-dim">
        arcane.orion © 2026
      </div>
    </footer>
  </div>
</BaseLayout>
