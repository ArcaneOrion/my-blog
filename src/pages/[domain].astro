---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import StructureField from '../components/StructureField.astro';
import katex from 'katex';
import { getCollection } from 'astro:content';
import { domains, pathFor, type DomainName } from '../lib/site';

export async function getStaticPaths() {
  return [
    { params: { domain: 'math' } },
    { params: { domain: 'ai' } },
    { params: { domain: 'quant' } },
    { params: { domain: 'journal' } },
  ];
}

const { domain } = Astro.params;
const domainTagMap: Record<string, DomainName> = {
  math: 'Math',
  ai: 'AI',
  quant: 'Quant',
  journal: 'Journal',
};
const domainTag = domainTagMap[domain as string];
const info = domains[domainTag];

const formulaHtml = katex.renderToString(info.formula, { throwOnError: false, displayMode: false });

const allPosts = await getCollection('blog', (p) => !p.data.draft);
const posts = allPosts
  .filter((p) => p.data.tags.includes(domainTag))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`${info.title} — Arcane Orion`}>
  <StructureField mode={info.id} projection />
  <a href={pathFor('/observatory')} class="return-anchor">← observatory</a>
  <div class="relative z-10">
    <main class="page-shell py-16">
      <header class={`domain-${info.id} grid gap-8 py-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end`}>
        <div>
          <p class="axis-label text-domain">{info.phrase}</p>
          <h1 class="mt-4 font-display text-5xl font-bold leading-none text-arcane-text md:text-7xl">
            {info.title}
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-arcane-text-secondary">
            {posts.length} 篇
          </p>
        </div>

        <div class="observatory-panel grid grid-cols-[auto_1fr] items-center gap-6 p-6">
          <p class="domain-glyph text-7xl text-domain leading-none">{info.glyph}</p>
          <span class="domain-formula justify-self-center text-lg text-domain opacity-80" set:html={formulaHtml} />
        </div>
      </header>

      {posts.length > 0 ? (
        <section class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-2">
          {posts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date.toLocaleDateString('zh-CN')}
              tags={post.data.tags}
              slug={post.slug}
              aiAssisted={post.data.aiAssisted}
              body={post.body}
            />
          ))}
        </section>
      ) : (
        <section class="mt-8 observatory-panel p-12 text-center">
          <p class="font-display text-3xl text-arcane-text-dim">还没有文章。</p>
        </section>
      )}
    </main>
  </div>
</BaseLayout>

<style>
  .domain-glyph {
    font-family: 'Italiana', 'Cormorant Garamond', 'STIX Two Math', 'Cambria Math', 'Apple Symbols', 'Noto Sans Math', 'Noto Sans Symbols 2', 'Segoe UI Symbol', 'DejaVu Sans', 'Georgia', serif;
  }
  .domain-formula :global(.katex) {
    color: inherit;
  }
</style>
