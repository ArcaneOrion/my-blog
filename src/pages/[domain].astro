---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import StructureField from '../components/StructureField.astro';
import { getCollection } from 'astro:content';
import { domains, pathFor, type DomainName } from '../lib/site';

export async function getStaticPaths() {
  return [
    { params: { domain: 'math' } },
    { params: { domain: 'ai' } },
    { params: { domain: 'quant' } },
  ];
}

const { domain } = Astro.params;
const domainTagMap: Record<string, DomainName> = {
  math: 'Math',
  ai: 'AI',
  quant: 'Quant',
};
const domainTag = domainTagMap[domain as string];
const info = domains[domainTag];

const allPosts = await getCollection('blog', (p) => !p.data.draft);
const posts = allPosts
  .filter((p) => p.data.tags.includes(domainTag))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`${info.title} — Arcane Orion`}>
  <StructureField mode={info.id} projection />
  <a href={pathFor('/observatory')} class="return-anchor">← observatory</a>
  <div class="relative z-10">
    <main class="page-shell py-16">
      <header class={`domain-${info.id} grid gap-8 py-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end`}>
        <div>
          <p class="axis-label text-domain">{info.phrase}</p>
          <h1 class="mt-4 font-display text-5xl font-bold leading-none text-arcane-text md:text-7xl">
            {info.title}
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-arcane-text-secondary">
            {posts.length} 篇{info.label}记录 · 第 {info.id === 'math' ? '一' : info.id === 'ai' ? '二' : '三'}个结构域的投影
          </p>
        </div>

        <div class="observatory-panel flex items-center justify-between p-6">
          <div>
            <p class="font-mono text-[0.62rem] uppercase tracking-[0.32em] text-arcane-text-dim">domain operator</p>
            <p class="mt-3 font-display text-5xl text-domain">{info.glyph}</p>
          </div>
        </div>
      </header>

      {posts.length > 0 ? (
        <section class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-2">
          {posts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date.toLocaleDateString('zh-CN')}
              tags={post.data.tags}
              slug={post.slug}
              aiAssisted={post.data.aiAssisted}
              body={post.body}
            />
          ))}
        </section>
      ) : (
        <section class="mt-8 observatory-panel p-12 text-center">
          <p class="font-display text-3xl text-arcane-text-dim">这个结构域还没有投影记录。</p>
          <p class="mt-4 font-mono text-[0.62rem] uppercase tracking-[0.32em] text-arcane-text-dim">awaiting first observation</p>
        </section>
      )}
    </main>
  </div>
</BaseLayout>
