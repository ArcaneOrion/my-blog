---
import BaseLayout from '../layouts/BaseLayout.astro';
import StructureField from '../components/StructureField.astro';
import { pathFor } from '../lib/site';
---

<BaseLayout title="Journal — Arcane Orion">
  <StructureField mode="journal" projection />
  <a href={pathFor('/observatory')} class="return-anchor">← observatory</a>
  <div class="relative z-10">
    <main class="page-shell py-16">
      <header class="grid gap-8 py-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <div>
          <h1 class="mt-4 font-display text-5xl font-bold leading-none text-arcane-text md:text-7xl">
            Journal
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-arcane-text-secondary">
            临时想法和短记录
          </p>
        </div>

        <div class="observatory-panel flex items-center justify-between p-6">
          <div>
            <p class="mt-3 font-display text-5xl" style="color: #b08940">∿</p>
          </div>
        </div>
      </header>

      <section class="mt-8 observatory-panel p-12 text-center">
        <p class="font-display text-3xl text-arcane-text-dim">还没有内容。</p>
      </section>
    </main>
  </div>
</BaseLayout>
