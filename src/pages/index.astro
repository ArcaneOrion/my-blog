---
import BaseLayout from '../layouts/BaseLayout.astro';
import StructureField from '../components/StructureField.astro';
import { scenes } from '../scenes';

const heroScene = scenes[0];
const sectionScenes = scenes.slice(1);

function italicLines(text: string) {
  return text.split('\n');
}

// 每个 scene 的诗句对齐方式：决定 narrative 容器锚点对齐到容器的哪个角
const narrativeAlign: Record<string, 'left' | 'right' | 'center-bottom' | 'center-top'> = {
  'linear-algebra': 'left',
  analysis: 'right',
  probability: 'left',
  gateway: 'center-bottom',
};
---

<BaseLayout title="Arcane Orion — Structure Observatory">
  <StructureField mode="math" />

  <aside class="sys-info" data-sys-info aria-hidden="true">
    <p data-sys-line="space">{heroScene.sysInfo.space}</p>
    <p data-sys-line="status">{heroScene.sysInfo.status}</p>
    <p data-sys-line="object" class="text-arcane-text-dim/60">{heroScene.sysInfo.object}</p>
  </aside>

  {/* Narrative 层：诗句独立浮层，由 canvas scene 几何锚点驱动 */}
  <div class="narrative-layer" aria-hidden="false">
    {sectionScenes.map((scene) => (
      <div
        class="narrative-quote"
        data-narrative-scene={scene.id}
        data-narrative-align={narrativeAlign[scene.id] || 'left'}
      >
        {italicLines(scene.copy.italicCopy).map((line) => (
          <span class="block">{line || ' '}</span>
        ))}
      </div>
    ))}
  </div>

  <div class="relative z-10 page-fade-in">
    <main class="relative">
      {/* Hero: entry scene，保留现有 fade-in 排版（不走 narrative） */}
      <section
        class="page-shell home-stage home-stage--hero relative flex items-center"
        data-stage={heroScene.id}
      >
        <div class="max-w-5xl pt-10">
          <p class="fade-in-delay-1 font-mono text-[0.62rem] uppercase tracking-[0.42em] text-arcane-text-dim">
            mathematics · structure · mystery
          </p>

          <h1
            class="narrative-hero mt-10 font-display text-[clamp(5.5rem,17vw,15rem)] font-normal leading-[0.82] text-arcane-text"
            data-narrative-scene="entry"
            data-hero-title
          >
            Arcane<span class="text-arcane-math">.</span><br />
            Orion
          </h1>

          <p class="fade-in-delay-3 mt-10 max-w-xl text-[1.1rem] leading-[1.9] text-arcane-text-secondary md:text-[1.18rem]">
            {italicLines(heroScene.copy.italicCopy).map((line) => (
              <span class="italic block" style="font-family: var(--font-italic); font-weight: 400;">
                {line || ' '}
              </span>
            ))}
          </p>
        </div>
      </section>

      {/* 4 个 stage：诗句已外移到 narrative 层，section 内只剩 sectionLabel + sideNote */}
      {sectionScenes.map((scene) => {
        const textOnLeft = scene.anchor.x > 0.5;
        return (
          <section
            class="page-shell home-stage flex items-center"
            data-stage={scene.id}
            data-reveal
          >
            <div class:list={[
              'grid w-full gap-12 items-end',
              textOnLeft ? 'lg:grid-cols-[1fr_0.72fr]' : 'lg:grid-cols-[0.72fr_1fr]',
            ]}>
              {/* sectionLabel：作为 section 边界标识，固定在视觉栏 */}
              <div class:list={[
                'self-end',
                textOnLeft ? 'order-1' : 'order-1 lg:text-right lg:order-2',
              ]}>
                <p class="font-mono text-[0.62rem] uppercase tracking-[0.42em] text-arcane-math" data-reveal-child>
                  {scene.copy.sectionLabel}
                </p>
              </div>

              {/* sideNote */}
              <div class:list={[
                'self-end pb-2',
                textOnLeft ? 'lg:text-right order-2' : 'order-2 lg:order-1',
              ]}>
                {scene.copy.sideNote && (
                  <p class="font-mono text-[0.58rem] uppercase tracking-[0.32em] text-arcane-text-dim leading-[1.9]" data-reveal-child>
                    {scene.copy.sideNote.split('\n').map((line) => (
                      <span class="block">{line}</span>
                    ))}
                  </p>
                )}
              </div>
            </div>
          </section>
        );
      })}
    </main>
  </div>

  <script>
    import { scenes, scenesById } from '../scenes';
    import { initScrollReveal } from '../lib/scroll-reveal';
    import { initNarrativeBind } from '../lib/narrative-bind';

    // 透传给 gateway scene 的 onClick：base URL 用于拼跳转 URL
    (window as any).__BLOG_BASE__ = import.meta.env.BASE_URL.replace(/\/$/, '');

    const stages = Array.from(document.querySelectorAll('[data-stage]'));

    function updateSysInfo(stageId: string) {
      const scene = scenesById[stageId];
      if (!scene) return;
      const root = document.querySelector('[data-sys-info]');
      if (!root) return;
      const lines = root.querySelectorAll<HTMLElement>('[data-sys-line]');
      lines.forEach((el) => {
        const key = el.getAttribute('data-sys-line') as keyof typeof scene.sysInfo;
        if (key && scene.sysInfo[key]) {
          el.textContent = scene.sysInfo[key];
        }
      });
    }

    const dispatchStage = (stage: string) => {
      window.dispatchEvent(new CustomEvent('structure-stage', {
        detail: { stage },
      }));
      updateSysInfo(stage);
    };

    if (stages.length > 0) {
      dispatchStage(stages[0].getAttribute('data-stage') || scenes[0].id);

      const stageObserver = new IntersectionObserver((entries) => {
        const active = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (active) {
          dispatchStage(active.target.getAttribute('data-stage') || scenes[0].id);
        }
      }, {
        threshold: [0.08, 0.25, 0.5],
      });

      stages.forEach((stage) => stageObserver.observe(stage));
    }

    // sectionLabel / sideNote 还在用 reveal 流，保留
    initScrollReveal();

    // 诗句 narrative 层：锚定到 canvas scene 几何
    initNarrativeBind();

    // hero 大字 bbox 测量,供 entry scene drawLayers 在大字附近画装饰
    const heroTitle = document.querySelector<HTMLElement>('[data-hero-title]');
    function updateHeroBox() {
      if (!heroTitle) {
        (window as any).__heroBox = null;
        return;
      }
      const rect = heroTitle.getBoundingClientRect();
      // 估算大字 "." 位置:第一行 "Arcane." 末尾,占大字 width 约 0.38-0.42,y 约 line 1 baseline
      // 大字 2 行 leading 0.82,第一行 baseline 约 height * 0.42
      (window as any).__heroBox = {
        x: rect.left,
        y: rect.top,
        w: rect.width,
        h: rect.height,
        baselineY: rect.top + rect.height * 0.92,
        dotX: rect.left + rect.width * 0.40,
        dotY: rect.top + rect.height * 0.42,
      };
    }
    updateHeroBox();
    window.addEventListener('resize', updateHeroBox);
    if (heroTitle && typeof ResizeObserver !== 'undefined') {
      new ResizeObserver(updateHeroBox).observe(heroTitle);
    }
  </script>
</BaseLayout>
