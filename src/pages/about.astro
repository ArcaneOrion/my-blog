---
import BaseLayout from '../layouts/BaseLayout.astro';
import StructureField from '../components/StructureField.astro';
import { domains, pathFor } from '../lib/site';

const domainList = Object.values(domains);
---

<BaseLayout title="About — Arcane Orion">
  <StructureField mode="self" projection />
  <a href={pathFor('/observatory')} class="return-anchor">← observatory</a>
  <div class="relative z-10">
    <main class="page-shell py-16">
      <section class="grid gap-10 py-10 lg:grid-cols-[0.82fr_1.18fr]">
        <div>
          <h1 class="mt-4 font-display text-5xl font-bold leading-none text-arcane-text md:text-7xl">
            About
          </h1>
          <p class="mt-8 max-w-xl text-lg leading-8 text-arcane-text-secondary">
            我是 arcane orion。这个博客记录我在学的东西和一些想法，主要围绕数学、AI 和量化。
          </p>
        </div>

        <div class="observatory-panel p-6 md:p-8">
          <p class="axis-label">motto</p>
          <blockquote class="mt-5 border-l-2 border-arcane-math pl-5 font-display text-2xl leading-relaxed text-arcane-text md:text-3xl">
            没有结构，就没有理解。
          </blockquote>
        </div>
      </section>

      <section class="grid gap-5 py-10 md:grid-cols-3">
        {domainList.map(domain => (
          <div class={`domain-${domain.id} observatory-panel p-6`}>
            <div class="geometric-mark mb-8">
              <span class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 font-mono text-xl text-domain">{domain.glyph}</span>
            </div>
            <p class="axis-label text-domain">{domain.label}</p>
            <h2 class="mt-3 font-display text-xl text-arcane-text">{domain.title}</h2>
            <p class="mt-4 font-mono text-[0.72rem] uppercase leading-6 text-arcane-text-dim">{domain.phrase}</p>
          </div>
        ))}
      </section>

      <section class="py-10 max-w-md">
        <div class="observatory-panel p-6 md:p-8">
          <p class="axis-label">contact</p>
          <h2 class="mt-4 font-display text-2xl text-arcane-text">Arcane Orion</h2>
          <a
            href="https://github.com/arcaneorion"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-block border border-arcane-border px-4 py-3 font-mono text-xs uppercase text-arcane-text-secondary transition-colors hover:border-arcane-math/20 hover:text-arcane-math"
          >
            github / arcaneorion
          </a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
