---
---

<div class="world-manifold" data-constellation>
  <div class="world-manifold__canvas" data-constellation-container></div>

  <header class="world-manifold__header">
    <p class="world-manifold__eyebrow">WORLD MANIFOLD // 五世界观测场</p>
    <h1>Arcane Observatory</h1>
    <div class="world-manifold__equation" data-equation-display>
      Attractor Equations (Overview):<br />
      dx/dt = σ(y - x)<br />
      dy/dt = x(ρ - z) - y<br />
      dz/dt = xy - βz
    </div>
  </header>

  <div class="world-manifold-label" data-constellation-label aria-live="polite"></div>

  <button class="world-manifold__reset" type="button" data-reset-view>RESET VIEW</button>

  <aside class="world-panel" data-world-panel aria-live="polite">
    <p class="world-panel__index" data-world-index>NULL SET</p>
    <h2 data-world-title>VOID</h2>
    <p class="world-panel__glyph" data-world-glyph>∅</p>
    <p class="world-panel__body" data-world-body>Choose a manifold node to unfold one world.</p>
    <dl class="world-panel__meta">
      <div>
        <dt>space</dt>
        <dd data-world-space>∅</dd>
      </div>
      <div>
        <dt>state</dt>
        <dd data-world-state>unobserved</dd>
      </div>
    </dl>
    <button class="world-panel__enter" type="button" data-enter-world>ENTER WORLD</button>
  </aside>
</div>

<script>
  import * as THREE from 'three';

  type ColorTuple = [number, number, number];
  type SystemState = 'OVERVIEW' | 'FOCUSED' | 'ENTERING';

  interface NodeData {
    id: string;
    label: string;
    title: string;
    sub: string;
    content: string;
    glyph: string;
    color: number;
    colorTuple: ColorTuple;
    href: string;
    position: THREE.Vector3;
    planetSize: number;
    layer: 'tech' | 'humane';
    type: 'icosahedron_ring' | 'octahedron_core' | 'dodecahedron_grid' | 'tetrahedron_cloud' | 'ring_particles';
    paramChange: { sigma: number; rho: number; beta: number };
  }

  const palette = {
    math: 0x1d4ed8,
    ai: 0xbe185d,
    quant: 0x0f766e,
    self: 0x7c3aed,
    journal: 0xb08940,
    ink: 0x17181c,
  };

  const paletteTuple: Record<string, ColorTuple> = {
    math: [29, 78, 216],
    ai: [190, 24, 93],
    quant: [15, 118, 110],
    self: [124, 58, 237],
    journal: [176, 137, 64],
    ink: [23, 24, 28],
  };

  function rgbStyle(c: ColorTuple, a: number): string {
    return `rgba(${c[0]}, ${c[1]}, ${c[2]}, ${a})`;
  }

  function makeConstellation(root: HTMLElement) {
    if (root.dataset.constellationReady === 'true') return;
    root.dataset.constellationReady = 'true';

    const containerMaybe = root.querySelector<HTMLDivElement>('[data-constellation-container]');
    const labelMaybe = root.querySelector<HTMLDivElement>('[data-constellation-label]');
    const panelMaybe = root.querySelector<HTMLElement>('[data-world-panel]');
    const resetMaybe = root.querySelector<HTMLButtonElement>('[data-reset-view]');
    const enterMaybe = root.querySelector<HTMLButtonElement>('[data-enter-world]');
    const equationMaybe = root.querySelector<HTMLElement>('[data-equation-display]');
    const worldIndexMaybe = root.querySelector<HTMLElement>('[data-world-index]');
    const worldTitleMaybe = root.querySelector<HTMLElement>('[data-world-title]');
    const worldGlyphMaybe = root.querySelector<HTMLElement>('[data-world-glyph]');
    const worldBodyMaybe = root.querySelector<HTMLElement>('[data-world-body]');
    const worldSpaceMaybe = root.querySelector<HTMLElement>('[data-world-space]');
    const worldStateMaybe = root.querySelector<HTMLElement>('[data-world-state]');
    if (!containerMaybe || !labelMaybe || !panelMaybe || !resetMaybe || !enterMaybe || !equationMaybe || !worldIndexMaybe || !worldTitleMaybe || !worldGlyphMaybe || !worldBodyMaybe || !worldSpaceMaybe || !worldStateMaybe) return;

    const container = containerMaybe;
    const labelEl = labelMaybe;
    const panelEl = panelMaybe;
    const resetBtn = resetMaybe;
    const enterBtn = enterMaybe;
    const equationEl = equationMaybe;
    const worldIndexEl = worldIndexMaybe;
    const worldTitleEl = worldTitleMaybe;
    const worldGlyphEl = worldGlyphMaybe;
    const worldBodyEl = worldBodyMaybe;
    const worldSpaceEl = worldSpaceMaybe;
    const worldStateEl = worldStateMaybe;

    const sysStateEl = document.querySelector('[data-sys-state]');
    const sysStatusEl = document.querySelector('[data-sys-status]');
    const sysObjectEl = document.querySelector('[data-sys-object]');

    const updateSysInfo = (state: string, status: string, obj: string) => {
      if (sysStateEl) sysStateEl.textContent = `state · ${state}`;
      if (sysStatusEl) sysStatusEl.textContent = `status · ${status}`;
      if (sysObjectEl) sysObjectEl.textContent = `object · ${obj}`;
    };

    let width = container.clientWidth || window.innerWidth;
    let height = container.clientHeight || window.innerHeight;

    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0xfcfcfd);
    scene.fog = new THREE.FogExp2(0xfcfcfd, 0.024);

    const camera = new THREE.PerspectiveCamera(50, width / height, 0.1, 1000);
    const defaultCameraPos = new THREE.Vector3(0, 13, 32);
    const cameraTarget = new THREE.Vector3(0, 0, 0);
    const targetCameraPos = defaultCameraPos.clone();
    const targetLookAt = new THREE.Vector3(0, 0, 0);
    camera.position.copy(defaultCameraPos);
    camera.lookAt(cameraTarget);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(width, height);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    container.appendChild(renderer.domElement);

    scene.add(new THREE.AmbientLight(0xffffff, 0.95));
    const dirLight = new THREE.DirectionalLight(0xfff5ea, 0.45);
    dirLight.position.set(10, 28, 14);
    scene.add(dirLight);

    const gridGroup = new THREE.Group();
    const gridMat = new THREE.MeshBasicMaterial({
      color: 0xdadce5,
      wireframe: true,
      transparent: true,
      opacity: 0.28,
      depthWrite: false,
    });
    [10, 18, 27].forEach((radius) => {
      const sphere = new THREE.Mesh(new THREE.SphereGeometry(radius, 24, 16), gridMat.clone());
      gridGroup.add(sphere);
    });
    scene.add(gridGroup);

    const lorenzParams = { sigma: 10, rho: 28, beta: 8 / 3, speedScale: 1 };
    const lorenzTargets = { sigma: 10, rho: 28, beta: 8 / 3, speedScale: 1 };
    const lorenzGeometry = new THREE.BufferGeometry();
    const lorenzMaterial = new THREE.LineBasicMaterial({
      color: 0xcca050,
      transparent: true,
      opacity: 0.44,
    });
    const lorenzLine = new THREE.Line(lorenzGeometry, lorenzMaterial);
    scene.add(lorenzLine);

    function rebuildLorenz() {
      const points: THREE.Vector3[] = [];
      let x = 0.1;
      let y = 0;
      let z = 0;
      const dt = 0.008;
      for (let i = 0; i < 2200; i++) {
        const dx = lorenzParams.sigma * (y - x) * dt;
        const dy = (x * (lorenzParams.rho - z) - y) * dt;
        const dz = (x * y - lorenzParams.beta * z) * dt;
        x += dx;
        y += dy;
        z += dz;
        points.push(new THREE.Vector3(x * 0.35, (z - 25) * 0.35, y * 0.35));
      }
      lorenzGeometry.setFromPoints(points);
    }

    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();
    let hoveredNode: NodeData | null = null;
    let focusedNode: NodeData | null = null;
    let systemState: SystemState = 'OVERVIEW';
    let transitionProgress = 0;
    let paused = false;
    let pointerStartX = 0;
    let pointerStartY = 0;
    let pointerLastX = 0;
    let pointerLastY = 0;
    let dragDistance = 0;
    let isDraggingView = false;
    let hasNavigated = false;
    const defaultOrbit = {
      theta: 0,
      phi: Math.acos(defaultCameraPos.y / defaultCameraPos.length()),
      radius: defaultCameraPos.length(),
    };
    const orbit = { ...defaultOrbit };
    const orbitTarget = { ...defaultOrbit };
    const enteringStartCamera = new THREE.Vector3();
    const enteringStartLookAt = new THREE.Vector3();

    const blogRoot = (window as any).__BLOG_BASE__ || '';
    const url = (p: string) => {
      const base = blogRoot.endsWith('/') ? blogRoot : `${blogRoot}/`;
      const normalized = p.startsWith('/') ? p.slice(1) : p;
      return `${base}${normalized}`;
    };

    const nodesData: NodeData[] = [
      {
        id: 'math',
        label: 'Mathematics',
        title: 'DIMENSION A // 数学结构',
        sub: 'proof · abstraction · invariant',
        content: '这里是关于证明、分析、拓扑与抽象结构的世界。数学不是装饰符号，而是观察世界时保留下来的不变量。',
        glyph: '∂',
        color: palette.math,
        colorTuple: paletteTuple.math,
        href: url('/math/'),
        position: new THREE.Vector3(-10, 2, 3),
        planetSize: 1.8,
        layer: 'tech',
        type: 'icosahedron_ring',
        paramChange: { sigma: 15, rho: 12, beta: 2.0 },
      },
      {
        id: 'ai',
        label: 'Artificial Intelligence',
        title: 'DIMENSION B // 递归智能',
        sub: 'agency · context · optimization',
        content: '这里记录 agent、上下文工程、自我迭代与智能系统。节点像一个会回看自身状态的递归核心。',
        glyph: 'λ',
        color: palette.ai,
        colorTuple: paletteTuple.ai,
        href: url('/ai/'),
        position: new THREE.Vector3(8, 4, -4),
        planetSize: 1.9,
        layer: 'tech',
        type: 'octahedron_core',
        paramChange: { sigma: 10, rho: 40, beta: 8 / 3 },
      },
      {
        id: 'quant',
        label: 'Quantitative Thinking',
        title: 'DIMENSION C // 市场相空间',
        sub: 'signal · risk · feedback',
        content: '这里承载量化思维、动量、风险曲面与反馈系统。价格不是点，而是噪声、信号和约束共同生成的轨迹。',
        glyph: 'σ',
        color: palette.quant,
        colorTuple: paletteTuple.quant,
        href: url('/quant/'),
        position: new THREE.Vector3(10, -4, 3),
        planetSize: 1.7,
        layer: 'tech',
        type: 'dodecahedron_grid',
        paramChange: { sigma: 4, rho: 28, beta: 4.0 },
      },
      {
        id: 'self',
        label: 'Self',
        title: 'DIMENSION D // 观测者原点',
        sub: 'observer · origin · profile',
        content: '这里不是履历页，而是坐标系的原点：谁在观察、以什么方式学习、用什么问题组织自己的轨道。',
        glyph: '·',
        color: palette.self,
        colorTuple: paletteTuple.self,
        href: url('/about/'),
        position: new THREE.Vector3(-4, -6, -7),
        planetSize: 1.15,
        layer: 'humane',
        type: 'tetrahedron_cloud',
        paramChange: { sigma: 7, rho: 22, beta: 3.2 },
      },
      {
        id: 'journal',
        label: 'Journal',
        title: 'DIMENSION E // 漂移日志',
        sub: 'drift · note · state',
        content: '这里保存阶段性笔记、状态切片与未完成的观察。它不像文章那样闭合，更像仍在运动的时间环。',
        glyph: '∿',
        color: palette.journal,
        colorTuple: paletteTuple.journal,
        href: url('/journal/'),
        position: new THREE.Vector3(0, 1, 9),
        planetSize: 1.15,
        layer: 'humane',
        type: 'ring_particles',
        paramChange: { sigma: 12, rho: 34, beta: 2.25 },
      },
    ];

    const nodesGroup = new THREE.Group();
    scene.add(nodesGroup);

    interface WorldObject {
      data: NodeData;
      group: THREE.Group;
      coreMesh: THREE.Mesh | THREE.Points;
      outerStructures: THREE.Object3D[];
      basePosition: THREE.Vector3;
    }

    const worlds: WorldObject[] = [];
    const raycastTargets: THREE.Object3D[] = [];

    function createNodeObject(node: NodeData) {
      const pGroup = new THREE.Group();
      pGroup.position.copy(node.position);
      pGroup.userData = { id: node.id };

      const outerStructures: THREE.Object3D[] = [];
      let coreMesh: THREE.Mesh | THREE.Points;

      if (node.type === 'icosahedron_ring') {
        coreMesh = new THREE.Mesh(
          new THREE.IcosahedronGeometry(node.planetSize, 1),
          new THREE.MeshBasicMaterial({ color: node.color, wireframe: true, transparent: true, opacity: 0.2 }),
        );
        pGroup.add(coreMesh);

        const ring = new THREE.Mesh(
          new THREE.RingGeometry(node.planetSize * 1.35 - 0.02, node.planetSize * 1.35 + 0.02, 56),
          new THREE.MeshBasicMaterial({ color: node.color, side: THREE.DoubleSide, transparent: true, opacity: 0.26 }),
        );
        ring.rotation.x = Math.PI / 2.3;
        ring.rotation.y = Math.PI / 8;
        pGroup.add(ring);
        outerStructures.push(ring);
      } else if (node.type === 'octahedron_core') {
        const outerMesh = new THREE.Mesh(
          new THREE.OctahedronGeometry(node.planetSize, 1),
          new THREE.MeshBasicMaterial({ color: node.color, wireframe: true, transparent: true, opacity: 0.18 }),
        );
        pGroup.add(outerMesh);
        outerStructures.push(outerMesh);

        coreMesh = new THREE.Mesh(
          new THREE.DodecahedronGeometry(node.planetSize * 0.42, 0),
          new THREE.MeshBasicMaterial({ color: node.color, transparent: true, opacity: 0.14 }),
        );
        pGroup.add(coreMesh);

        const ring = new THREE.Mesh(
          new THREE.RingGeometry(node.planetSize * 1.4 - 0.02, node.planetSize * 1.4 + 0.02, 56),
          new THREE.MeshBasicMaterial({ color: node.color, side: THREE.DoubleSide, transparent: true, opacity: 0.22 }),
        );
        ring.rotation.y = Math.PI / 2;
        pGroup.add(ring);
        outerStructures.push(ring);
      } else if (node.type === 'dodecahedron_grid') {
        const mesh = new THREE.Mesh(
          new THREE.DodecahedronGeometry(node.planetSize, 1),
          new THREE.MeshBasicMaterial({ color: node.color, wireframe: true, transparent: true, opacity: 0.18 }),
        );
        pGroup.add(mesh);
        outerStructures.push(mesh);

        coreMesh = new THREE.Points(
          new THREE.IcosahedronGeometry(node.planetSize * 0.68, 1),
          new THREE.PointsMaterial({ color: node.color, size: 0.08, transparent: true, opacity: 0.42 }),
        );
        pGroup.add(coreMesh);
      } else if (node.type === 'tetrahedron_cloud') {
        coreMesh = new THREE.Mesh(
          new THREE.TetrahedronGeometry(node.planetSize * 0.55, 1),
          new THREE.MeshBasicMaterial({ color: node.color, wireframe: true, transparent: true, opacity: 0.24 }),
        );
        pGroup.add(coreMesh);

        const cloudMesh = new THREE.Mesh(
          new THREE.IcosahedronGeometry(node.planetSize * 1.1, 0),
          new THREE.MeshBasicMaterial({ color: node.color, wireframe: true, transparent: true, opacity: 0.1 }),
        );
        pGroup.add(cloudMesh);
        outerStructures.push(cloudMesh);
      } else {
        coreMesh = new THREE.Mesh(
          new THREE.OctahedronGeometry(node.planetSize * 0.5, 0),
          new THREE.MeshBasicMaterial({ color: node.color, wireframe: true, transparent: true, opacity: 0.26 }),
        );
        pGroup.add(coreMesh);

        const ringParticleGeom = new THREE.BufferGeometry();
        const particleCount = 56;
        const positions = new Float32Array(particleCount * 3);
        const r = node.planetSize * 1.25;
        for (let i = 0; i < particleCount; i++) {
          const theta = (i / particleCount) * Math.PI * 2;
          positions[i * 3] = Math.cos(theta) * r + (Math.random() - 0.5) * 0.1;
          positions[i * 3 + 1] = (Math.random() - 0.5) * 0.06;
          positions[i * 3 + 2] = Math.sin(theta) * r + (Math.random() - 0.5) * 0.1;
        }
        ringParticleGeom.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        const points = new THREE.Points(
          ringParticleGeom,
          new THREE.PointsMaterial({ color: node.color, size: 0.05, transparent: true, opacity: 0.48 }),
        );
        pGroup.add(points);
        outerStructures.push(points);
      }

      const hitMesh = new THREE.Mesh(
        new THREE.SphereGeometry(node.planetSize * 1.8, 16, 16),
        new THREE.MeshBasicMaterial({ visible: false, depthWrite: false }),
      );
      hitMesh.userData = { isHitZone: true, nodeId: node.id };
      pGroup.add(hitMesh);
      raycastTargets.push(hitMesh);

      nodesGroup.add(pGroup);
      worlds.push({ data: node, group: pGroup, coreMesh, outerStructures, basePosition: node.position.clone() });
    }

    nodesData.forEach(createNodeObject);

    const linesGroup = new THREE.Group();
    scene.add(linesGroup);
    const connectionPairs = [
      ['math', 'ai'],
      ['ai', 'quant'],
      ['math', 'quant'],
      ['self', 'journal'],
      ['self', 'ai'],
      ['journal', 'math'],
      ['journal', 'quant'],
    ];
    const connectionLines = connectionPairs.map(([fromId, toId]) => {
      const geom = new THREE.BufferGeometry();
      geom.setAttribute('position', new THREE.BufferAttribute(new Float32Array(6), 3));
      const line = new THREE.Line(
        geom,
        new THREE.LineBasicMaterial({ color: 0x17181c, transparent: true, opacity: 0.07 }),
      );
      linesGroup.add(line);
      return { line, fromId, toId };
    });

    function updateConnectionLines() {
      connectionLines.forEach(({ line, fromId, toId }) => {
        const from = worlds.find((world) => world.data.id === fromId);
        const to = worlds.find((world) => world.data.id === toId);
        if (!from || !to) return;

        const positions = line.geometry.attributes.position.array as Float32Array;
        positions[0] = from.group.position.x;
        positions[1] = from.group.position.y;
        positions[2] = from.group.position.z;
        positions[3] = to.group.position.x;
        positions[4] = to.group.position.y;
        positions[5] = to.group.position.z;
        line.geometry.attributes.position.needsUpdate = true;

        const involved = hoveredNode && (hoveredNode.id === fromId || hoveredNode.id === toId);
        const focused = focusedNode && (focusedNode.id === fromId || focusedNode.id === toId);
        const mat = line.material as THREE.LineBasicMaterial;
        if (involved || focused) {
          const source = focusedNode || hoveredNode!;
          mat.color.setHex(source.color);
          mat.opacity += (0.34 - mat.opacity) * 0.12;
        } else {
          mat.color.setHex(0x17181c);
          mat.opacity += (0.07 - mat.opacity) * 0.12;
        }
      });
    }

    function updateLabel() {
      if (!hoveredNode || systemState !== 'OVERVIEW') {
        labelEl.classList.remove('is-visible');
        return;
      }

      const world = worlds.find((item) => item.data.id === hoveredNode!.id);
      if (!world) return;

      const tempV = new THREE.Vector3();
      world.group.getWorldPosition(tempV);
      tempV.project(camera);

      const lx = (tempV.x * 0.5 + 0.5) * width;
      const ly = (tempV.y * -0.5 + 0.5) * height;

      labelEl.style.setProperty('--lx', `${lx}px`);
      labelEl.style.setProperty('--ly', `${ly - world.data.planetSize * 15 - 32}px`);
      labelEl.style.setProperty('--lc', rgbStyle(world.data.colorTuple, 0.95));
      labelEl.innerHTML = `
        <span class="world-manifold-label__main">${world.data.glyph} ─ ${world.data.label}</span>
        <span class="world-manifold-label__sub">${world.data.sub}</span>
      `;
      labelEl.classList.add('is-visible');
    }

    function updateOrbitCameraTarget(center: THREE.Vector3) {
      const sinPhi = Math.sin(orbit.phi);
      targetCameraPos.set(
        center.x + orbit.radius * sinPhi * Math.sin(orbit.theta),
        center.y + orbit.radius * Math.cos(orbit.phi),
        center.z + orbit.radius * sinPhi * Math.cos(orbit.theta),
      );
      targetLookAt.copy(center);
    }

    function syncPanel(node: NodeData) {
      worldIndexEl.textContent = node.title;
      worldTitleEl.textContent = node.label;
      worldGlyphEl.textContent = node.glyph;
      worldBodyEl.textContent = node.content;
      worldSpaceEl.textContent = node.sub;
      worldStateEl.textContent = `σ ${node.paramChange.sigma.toFixed(1)} · ρ ${node.paramChange.rho.toFixed(1)} · β ${node.paramChange.beta.toFixed(2)}`;
    }

    function focusNode(node: NodeData) {
      focusedNode = node;
      hoveredNode = null;
      systemState = 'FOCUSED';
      labelEl.classList.remove('is-visible');
      panelEl.classList.add('is-active');
      resetBtn.classList.add('is-visible');
      syncPanel(node);
      updateSysInfo(node.id, 'focused', node.label);

      lorenzTargets.sigma = node.paramChange.sigma;
      lorenzTargets.rho = node.paramChange.rho;
      lorenzTargets.beta = node.paramChange.beta;
      lorenzTargets.speedScale = 2.1;

      orbitTarget.theta = Math.atan2(camera.position.x - node.position.x, camera.position.z - node.position.z);
      orbitTarget.phi = window.innerWidth <= 700 ? 1.25 : 1.38;
      orbitTarget.radius = window.innerWidth <= 700 ? 9.2 : 7.2;

      equationEl.innerHTML = `
        Warped State (${node.id.toUpperCase()}):<br />
        σ = ${node.paramChange.sigma.toFixed(1)}<br />
        ρ = ${node.paramChange.rho.toFixed(1)}<br />
        β = ${node.paramChange.beta.toFixed(2)}
      `;
    }

    function resetView() {
      focusedNode = null;
      systemState = 'OVERVIEW';
      panelEl.classList.remove('is-active');
      resetBtn.classList.remove('is-visible');
      updateSysInfo('five nodes', 'waiting', 'manifold');

      lorenzTargets.sigma = 10;
      lorenzTargets.rho = 28;
      lorenzTargets.beta = 8 / 3;
      lorenzTargets.speedScale = 1;
      orbitTarget.theta = defaultOrbit.theta;
      orbitTarget.phi = defaultOrbit.phi;
      orbitTarget.radius = defaultOrbit.radius;
      targetLookAt.set(0, 0, 0);
      equationEl.innerHTML = `
        Attractor Equations (Overview):<br />
        dx/dt = σ(y - x)<br />
        dy/dt = x(ρ - z) - y<br />
        dz/dt = xy - βz
      `;
    }

    function enterWorld() {
      if (!focusedNode || systemState === 'ENTERING') return;
      systemState = 'ENTERING';
      transitionProgress = 0;
      hasNavigated = false;
      enteringStartCamera.copy(camera.position);
      enteringStartLookAt.copy(cameraTarget);
      updateSysInfo(focusedNode.id, 'entering', focusedNode.label);
      panelEl.classList.remove('is-active');
      resetBtn.classList.remove('is-visible');
    }

    function resize() {
      const rect = container.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height);
    }

    function updateHover(clientX: number, clientY: number) {
      const rect = container.getBoundingClientRect();
      mouse.x = ((clientX - rect.left) / width) * 2 - 1;
      mouse.y = -((clientY - rect.top) / height) * 2 + 1;

      raycaster.setFromCamera(mouse, camera);
      const intersects = raycaster.intersectObjects(raycastTargets, true);
      const hit = intersects.find((item) => item.object.userData && item.object.userData.isHitZone);
      const found = hit ? nodesData.find((node) => node.id === hit.object.userData.nodeId) || null : null;

      if (found !== hoveredNode) {
        hoveredNode = found;
        container.style.cursor = found ? 'pointer' : 'grab';
        if (found) {
          updateSysInfo(found.id, 'ready', found.label);
        } else {
          updateSysInfo('five nodes', 'waiting', 'manifold');
        }
      }
    }

    function onPointerMove(event: PointerEvent) {
      const rect = container.getBoundingClientRect();
      mouse.x = ((event.clientX - rect.left) / width) * 2 - 1;
      mouse.y = -((event.clientY - rect.top) / height) * 2 + 1;

      if (isDraggingView && systemState !== 'ENTERING') {
        const dx = event.clientX - pointerLastX;
        const dy = event.clientY - pointerLastY;
        pointerLastX = event.clientX;
        pointerLastY = event.clientY;
        dragDistance += Math.abs(dx) + Math.abs(dy);
        orbitTarget.theta -= dx * 0.006;
        orbitTarget.phi = Math.max(0.32, Math.min(Math.PI - 0.32, orbitTarget.phi + dy * 0.005));
        container.style.cursor = 'grabbing';
        hoveredNode = null;
        labelEl.classList.remove('is-visible');
        return;
      }

      if (systemState !== 'OVERVIEW') return;
      updateHover(event.clientX, event.clientY);
    }

    function onPointerDown(event: PointerEvent) {
      if ((event.target as Element).closest('button') || (event.target as Element).closest('.world-panel')) return;
      pointerStartX = event.clientX;
      pointerStartY = event.clientY;
      pointerLastX = event.clientX;
      pointerLastY = event.clientY;
      dragDistance = 0;
      isDraggingView = systemState !== 'ENTERING';
      container.setPointerCapture(event.pointerId);
      container.style.cursor = 'grabbing';
    }

    function onPointerUp(event: PointerEvent) {
      if (isDraggingView) {
        isDraggingView = false;
        if (container.hasPointerCapture(event.pointerId)) container.releasePointerCapture(event.pointerId);
        container.style.cursor = hoveredNode ? 'pointer' : 'grab';
      }

      if (systemState !== 'OVERVIEW' || !hoveredNode) return;
      if ((event.target as Element).closest('button') || (event.target as Element).closest('.world-panel')) return;
      const deltaX = Math.abs(event.clientX - pointerStartX);
      const deltaY = Math.abs(event.clientY - pointerStartY);
      if (deltaX > 8 || deltaY > 8 || dragDistance > 14) {
        updateHover(event.clientX, event.clientY);
        return;
      }
      focusNode(hoveredNode);
    }

    function onWheel(event: WheelEvent) {
      if (systemState === 'ENTERING') return;
      event.preventDefault();
      const minRadius = focusedNode ? 5.2 : 18;
      const maxRadius = focusedNode ? 15 : 46;
      orbitTarget.radius = Math.max(minRadius, Math.min(maxRadius, orbitTarget.radius + event.deltaY * 0.018));
    }

    function onPointerLeave() {
      if (systemState !== 'OVERVIEW') return;
      hoveredNode = null;
      isDraggingView = false;
      container.style.cursor = 'grab';
      updateSysInfo('five nodes', 'waiting', 'manifold');
    }

    function onVisibility() {
      paused = document.hidden;
      if (!paused) {
        const frameId = requestAnimationFrame(render);
        (window as any).__CONSTELLATION_FRAME_ID__ = frameId;
      }
    }

    let resizeFrame = 0;
    function onResize() {
      cancelAnimationFrame(resizeFrame);
      resizeFrame = requestAnimationFrame(resize);
    }

    function render(time: number) {
      if (paused) return;

      const frameId = requestAnimationFrame(render);
      (window as any).__CONSTELLATION_FRAME_ID__ = frameId;

      const elapsed = time * 0.001;
      lorenzParams.sigma += (lorenzTargets.sigma - lorenzParams.sigma) * 0.035;
      lorenzParams.rho += (lorenzTargets.rho - lorenzParams.rho) * 0.035;
      lorenzParams.beta += (lorenzTargets.beta - lorenzParams.beta) * 0.035;
      lorenzParams.speedScale += (lorenzTargets.speedScale - lorenzParams.speedScale) * 0.035;
      rebuildLorenz();
      lorenzLine.rotation.y = elapsed * 0.08 * lorenzParams.speedScale;

      gridGroup.rotation.y = elapsed * 0.02;
      gridGroup.rotation.x = Math.sin(elapsed * 0.12) * 0.04;
      const targetGridScale = focusedNode ? 0.82 : 1;
      gridGroup.scale.lerp(new THREE.Vector3(targetGridScale, targetGridScale, targetGridScale), 0.04);

      worlds.forEach((world, index) => {
        const isHovered = hoveredNode && hoveredNode.id === world.data.id;
        const isFocused = focusedNode && focusedNode.id === world.data.id;
        const floatY = Math.sin(elapsed * 0.7 + index * 1.9) * 0.16;
        const targetPos = world.basePosition.clone();
        targetPos.y += floatY;
        world.group.position.lerp(targetPos, 0.035);

        const rotSpeed = systemState === 'ENTERING' && isFocused ? 0.035 : isFocused ? 0.012 : isHovered ? 0.02 : 0.0045;
        world.coreMesh.rotation.y += rotSpeed;
        world.coreMesh.rotation.x += rotSpeed * 0.45;
        world.outerStructures.forEach((struct) => {
          struct.rotation.y -= rotSpeed * 0.75;
          struct.rotation.z += rotSpeed * 0.32;
        });

        if (systemState !== 'ENTERING') {
          const targetScale = isFocused ? 1.22 : isHovered ? 1.14 : 1;
          world.group.scale.lerp(new THREE.Vector3(targetScale, targetScale, targetScale), 0.12);
        }

        const targetOpacity = systemState === 'ENTERING' ? (isFocused ? 0.56 : 0.06) : isFocused ? 0.56 : isHovered ? 0.48 : 0.18;
        const mat = world.coreMesh.material as THREE.MeshBasicMaterial | THREE.PointsMaterial;
        mat.opacity += (targetOpacity - mat.opacity) * 0.12;
        world.outerStructures.forEach((struct) => {
          const material = (struct as THREE.Mesh | THREE.Points).material as THREE.MeshBasicMaterial | THREE.PointsMaterial | undefined;
          if (material) material.opacity += ((systemState === 'ENTERING' ? (isFocused ? 0.5 : 0.04) : isFocused || isHovered ? 0.52 : 0.18) - material.opacity) * 0.12;
        });
      });

      orbit.theta += (orbitTarget.theta - orbit.theta) * 0.09;
      orbit.phi += (orbitTarget.phi - orbit.phi) * 0.09;
      orbit.radius += (orbitTarget.radius - orbit.radius) * 0.09;

      if (systemState === 'ENTERING' && focusedNode) {
        transitionProgress = Math.min(1, transitionProgress + 0.018);
        const world = worlds.find((item) => item.data.id === focusedNode!.id);
        if (world) {
          const targetPos = world.group.position.clone();
          const direction = new THREE.Vector3().subVectors(targetPos, enteringStartCamera).normalize();
          const passThrough = targetPos.clone().add(direction.multiplyScalar(7.5));
          const ease = 1 - Math.pow(1 - transitionProgress, 4);
          const pulse = Math.sin(Math.min(1, transitionProgress * 1.4) * Math.PI);

          targetCameraPos.copy(enteringStartCamera).lerp(passThrough, ease);
          targetLookAt.copy(enteringStartLookAt).lerp(targetPos, Math.min(1, ease * 1.35));
          camera.fov = 50 + pulse * 28 + transitionProgress * 22;
          camera.updateProjectionMatrix();
          lorenzLine.scale.setScalar(1 + pulse * 0.22);
          (lorenzMaterial as THREE.LineBasicMaterial).opacity = Math.max(0, 0.44 * (1 - transitionProgress * 0.72));

          worlds.forEach((item) => {
            const targetScale = item.data.id === focusedNode!.id ? 1 + pulse * 1.45 : Math.max(0.25, 1 - ease * 0.88);
            item.group.scale.lerp(new THREE.Vector3(targetScale, targetScale, targetScale), 0.18);
            const mat = item.coreMesh.material as THREE.MeshBasicMaterial | THREE.PointsMaterial;
            const opacity = item.data.id === focusedNode!.id ? Math.max(0, 0.58 * (1 - transitionProgress * 0.88)) : Math.max(0, mat.opacity * (1 - transitionProgress * 0.08));
            mat.opacity += (opacity - mat.opacity) * 0.22;
          });
        }

        if (transitionProgress >= 0.86 && !hasNavigated) {
          hasNavigated = true;
          import('astro:transitions/client').then(({ navigate }) => {
            navigate(focusedNode!.href);
          });
        }
      } else {
        camera.fov += (50 - camera.fov) * 0.05;
        camera.updateProjectionMatrix();
        lorenzLine.scale.lerp(new THREE.Vector3(1, 1, 1), 0.06);
        (lorenzMaterial as THREE.LineBasicMaterial).opacity += (0.44 - (lorenzMaterial as THREE.LineBasicMaterial).opacity) * 0.06;
        updateOrbitCameraTarget(focusedNode ? focusedNode.position : new THREE.Vector3(0, 0, 0));
      }

      camera.position.lerp(targetCameraPos, systemState === 'ENTERING' ? 0.2 : 0.075);
      cameraTarget.lerp(targetLookAt, systemState === 'ENTERING' ? 0.18 : 0.08);
      camera.lookAt(cameraTarget);

      updateConnectionLines();
      updateLabel();
      renderer.render(scene, camera);
    }

    resetBtn.addEventListener('click', resetView);
    enterBtn.addEventListener('click', enterWorld);
    window.addEventListener('resize', onResize);
    window.addEventListener('pointermove', onPointerMove);
    container.addEventListener('pointerdown', onPointerDown);
    window.addEventListener('pointerup', onPointerUp);
    window.addEventListener('pointerleave', onPointerLeave);
    container.addEventListener('wheel', onWheel, { passive: false });
    document.addEventListener('visibilitychange', onVisibility);

    container.style.cursor = 'grab';
    resize();
    resetView();
    const initialFrame = requestAnimationFrame(render);
    (window as any).__CONSTELLATION_FRAME_ID__ = initialFrame;

    document.addEventListener('astro:before-swap', () => {
      const frameId = (window as any).__CONSTELLATION_FRAME_ID__;
      if (frameId) cancelAnimationFrame(frameId);
      cancelAnimationFrame(resizeFrame);
      resetBtn.removeEventListener('click', resetView);
      enterBtn.removeEventListener('click', enterWorld);
      window.removeEventListener('resize', onResize);
      window.removeEventListener('pointermove', onPointerMove);
      container.removeEventListener('pointerdown', onPointerDown);
      window.removeEventListener('pointerup', onPointerUp);
      window.removeEventListener('pointerleave', onPointerLeave);
      container.removeEventListener('wheel', onWheel);
      document.removeEventListener('visibilitychange', onVisibility);
      renderer.dispose();
      lorenzGeometry.dispose();
    }, { once: true });
  }

  function initConstellation() {
    const roots = document.querySelectorAll<HTMLElement>('[data-constellation]');
    roots.forEach(makeConstellation);
  }

  document.addEventListener('astro:page-load', initConstellation);
</script>

