---
import TagBadge from './TagBadge.astro';
import { pathFor, primaryDomain, readingMinutes } from '../lib/site';

interface Props {
  title: string;
  description: string;
  date: string;
  tags: string[];
  slug: string;
  aiAssisted?: boolean;
  body?: string;
}

const { title, description, date, tags, slug, aiAssisted, body = '' } = Astro.props;
const domain = primaryDomain(tags);
const minutes = body ? readingMinutes(body) : 1;
const href = pathFor(`/posts/${slug}`);
---

<article class={`group domain-${domain.id} observatory-panel relative min-h-[22rem] overflow-hidden p-5 transition-transform duration-300 hover:-translate-y-1`}>
  <div class="pointer-events-none absolute inset-0 opacity-70">
    <div class="absolute -right-10 -top-10 h-40 w-40 blur-3xl" style={`background: ${domain.darkTone}`}></div>
    <div class="absolute bottom-0 left-0 h-px w-full bg-gradient-to-r from-transparent via-[var(--domain-color)] to-transparent opacity-20"></div>
  </div>

  <div class="relative flex h-full flex-col">
    <div class="flex items-start justify-between gap-5">
      <div class="flex flex-wrap gap-2">
        {tags.map(tag => <TagBadge tag={tag} />)}
        {aiAssisted && (
          <span class="inline-flex items-center border border-arcane-border bg-white px-2.5 py-1 font-mono text-[0.66rem] uppercase text-arcane-text-dim">
            ai-assisted
          </span>
        )}
      </div>
      <div class="geometric-mark hidden shrink-0 opacity-80 sm:block">
        <span class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 font-mono text-xl text-domain">{domain.glyph}</span>
      </div>
    </div>

    <a href={href} class="mt-8 block">
      <p class="axis-label mb-3">{domain.phrase}</p>
      <h3 class="font-display text-2xl font-semibold leading-tight text-arcane-text transition-colors group-hover:text-domain">
        {title}
      </h3>
      <p class="mt-4 line-clamp-3 text-sm leading-7 text-arcane-text-secondary">
        {description}
      </p>
    </a>
    
    <div class="mt-auto flex items-end justify-between gap-4 pt-8">
      <div class="font-mono text-[0.72rem] uppercase text-arcane-text-dim">
        <time>{date}</time>
        <span class="mx-2 text-arcane-border">/</span>
        <span>{minutes} min</span>
      </div>
      <a 
        href={href}
        class="border border-arcane-border px-3 py-2 font-mono text-[0.68rem] uppercase text-domain transition-colors hover:border-domain hover:bg-domain-soft"
      >
        open record
      </a>
    </div>
  </div>
</article>
